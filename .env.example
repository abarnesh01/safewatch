# SafeWatch Environment Variables
# Copy this file to .env and fill in your values

# Telegram Bot Token (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram Chat IDs for alert agents
TELEGRAM_CHAT_ID_MAIN=your_main_agent_chat_id
TELEGRAM_CHAT_ID_PARKING=your_parking_agent_chat_id
