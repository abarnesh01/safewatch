# SafeWatch Environment Configuration

# Application Environment (development, production, test)
SAFEWATCH_ENV=production

# Security & Authentication
SAFEWATCH_SECRET_KEY=your_secure_random_secret_key_here
SESSION_TIMEOUT_MINUTES=60
