# SafeWatch — Advanced Runtime Isolation
# -------------------------------------------------------------

# Runtime Logs
logs/*
*.log

# Runtime Recordings & Assets
recordings/*
exports/*
snapshots/*

# Databases
*.db
*.sqlite
*.sqlite3

# Python Runtime & Cache
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/

# Virtual Environments
venv/
.env
.venv/
env/
ENV/

# Streamlit Runtime
.streamlit/
.streamlit-cache/

# VSCode / IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*~

# AI Models & Checkpoints
# (We only keep production-ready versions in Git)
models/checkpoints/
models/*.onnx
models/*.pt
models/*.pth

# Temporary Files
tmp/
temp/
*.tmp

# Telemetry & Runtime Caches
telemetry_cache/
runtime_cache/

# Dataset Artifacts
datasets/cache/
datasets/tmp/
training/data/
